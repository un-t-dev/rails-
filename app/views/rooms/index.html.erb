<div class="room-post-content">
    <h3>登録済みルーム一覧</h3>
    <table>
        <thead class="room-infomation">
            <th>ルーム画像</th>
            <th>エリア</th>
            <th>ルーム名</th>
            <th>ルーム紹介</th>
            <th>料金</th>
        </thead>
        <tbody class="room-user-infomation">
        <% @rooms.each do |room| %>
            <tr>
                <td><%= image_tag room.room_image.url, class: "image" %></td>
                <td><%= room.address %></td>
                <td><%= room.listing_name %></td>
                <td><%= room.room_type %></td>
                <td><%= room.price %></td>
            </tr>
        <% end %>    
        </tbody>    
   </table>
</div>